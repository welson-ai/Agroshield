{
  "name": "solmate-contracts",
  "version": "1.0.0",
  "description": "Solmate smart contracts for Celo",
    "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy-agroinvest.cjs --network celo --config hardhat.config.cjs",
    "deploy-solmate": "hardhat run scripts/deploy-solmate.cjs --network celo --config hardhat.config.cjs",
    "verify": "hardhat verify",
    "spin": "hardhat run scripts/spin-transactions.cjs --network celo --config hardhat.config.cjs",
    "generate": "hardhat run scripts/generate-wallets.cjs --network celo --config hardhat.config.cjs",
    "fund": "hardhat run scripts/fund-wallets.cjs --network celo --config hardhat.config.cjs",
    "ping": "hardhat run scripts/ping-contract.cjs --network celo --config hardhat.config.cjs",
    "boost": "hardhat run scripts/boost-dau.cjs --network celo --config hardhat.config.cjs",
    "check": "hardhat run scripts/check-yield.cjs --network celo --config hardhat.config.cjs"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "dotenv": "^16.3.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  }
}
