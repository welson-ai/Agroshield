# Server
PORT=3001
NODE_ENV=development

# Database (MySQL) – required for the backend to work
# Without a running MySQL and these vars, you'll see "connect ECONNREFUSED 127.0.0.1:3306"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tycoon
DB_USER=root
DB_PASSWORD=your_password

# --- Privy (Sign in with Privy) ---
# Required for "Sign in with Privy". Get from https://dashboard.privy.io/ → your app.
# PRIVY_APP_ID must match the frontend's NEXT_PUBLIC_PRIVY_APP_ID (same Privy app).
# Without these, POST /auth/privy-signin returns 503 "Privy not configured".
# PRIVY_APP_ID=clxxxxxxxxxx
# PRIVY_APP_SECRET=your-app-secret
# Optional: JWT verification key from Dashboard → Configuration → App settings. Avoids API call per verify; can fix "invalid or expired" if verification was failing.
# PRIVY_JWT_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional: skip Redis (no cache, no Redis process needed)
SKIP_REDIS=true

# Optional: Redis (when not using SKIP_REDIS)
# REDIS_URL=redis://127.0.0.1:6379

# --- Multi-chain Tycoon contract (backend game controller) ---
# Set the wallet as backendGameController on each chain's Tycoon contract (owner calls setBackendGameController).
# At least one chain must be configured for backend contract actions (create/join/end games, etc.).

# Celo (default when frontend sends chain=Celo)
CELO_RPC_URL=https://rpc.ankr.com/celo
# CELO_CHAIN_ID=42220 (mainnet) or 44787 (Alfajores). Default 42220.
TYCOON_CELO_CONTRACT_ADDRESS=
BACKEND_GAME_CONTROLLER_PRIVATE_KEY=
# Required for property purchase stats (setPropertyStats is only callable by gameFaucet, so backend routes via this faucet).
# Should match the on-chain gameFaucet set on the Tycoon proxy.
TYCOON_GAME_FAUCET_ADDRESS=
# --- Wallet-first signup (Privy users registered on-chain at signup). Required for new-user on-chain registration. ---
# New registry address from: cd contract && ./run-deploy-user-registry.sh (use the deployed TycoonUserRegistry address).
TYCOON_USER_REGISTRY_CELO=
# Registry owner key: same as contract/.env PRIVATE_KEY used to run run-deploy-user-registry.sh. createWalletForUserByBackend only allows gameContract or registry owner.
# Also used as the default signer for reward shop admin (stockShop / stockBundle) when set — must be owner, backendMinter, or gameMinter on TycoonRewardSystem.
TYCOON_OWNER_PRIVATE_KEY=
# Optional alias for the same key (if you prefer not to duplicate TYCOON_OWNER_PRIVATE_KEY):
# REGISTRY_OWNER_PRIVATE_KEY=
# Optional: override reward-stock signer only (else TYCOON_OWNER_PRIVATE_KEY, else BACKEND_GAME_CONTROLLER_*).
# REWARD_STOCK_MINTER_PRIVATE_KEY=
# Optional: protect POST /api/shop-admin/* and POST /api/tournaments/:id/admin-resolve with header x-shop-admin-secret (same value as frontend NEXT_PUBLIC_SHOP_ADMIN_SECRET if you use the Rewards page).
# SHOP_ADMIN_SECRET=

# Admin dashboard login (required for /admin UI and /api/admin/*).
# Set username/password used by the admin login form.
# TYCOON_ADMIN_USERNAME=admin
# TYCOON_ADMIN_PASSWORD=change-me
# Optional: secret used to sign admin JWTs. Falls back to JWT_SECRET when unset.
# TYCOON_ADMIN_JWT_SECRET=change-me-too
# Optional legacy bypass: protect /api/admin/* with x-tycoon-admin-secret header.
# TYCOON_ADMIN_SECRET=
# Referrals (no extra env): migration adds users.referral_code + referred_by_user_id. Player JWT: GET /api/referral/me, POST /api/referral/attach.
# Privy POST /auth/privy-signin may send referralCode or ref in JSON to attach after login/signup.
# Optional: comma-separated client IPs allowed to call /api/admin/* (evaluated after trust proxy). If unset, any IP may call (subject to secret + rate limit).
# TYCOON_ADMIN_IP_ALLOWLIST=127.0.0.1,::1
# Optional: stricter rate limit only for /api/admin/* (per IP per window). Defaults: 200 requests / 60s.
# TYCOON_ADMIN_RATE_LIMIT_MAX=200
# TYCOON_ADMIN_RATE_LIMIT_WINDOW_MS=60000

# Optional: daily login TYC voucher amounts (see dailyClaimController). Defaults: base 1 TYC, +0.5 TYC per streak day (max 7 bonus days in formula).
# DAILY_REWARD_TYC_BASE=1
# DAILY_REWARD_STREAK_BONUS_TYC=0.5
# Optional: reward contract address. If unset, backend reads Tycoon proxy's rewardSystem() (requires TYCOON_*_CONTRACT_ADDRESS + RPC).
# REWARD_CONTRACT_ADDRESS=
# Polygon (optional; for Polygon frontend)
# POLYGON_RPC_URL=
# POLYGON_CHAIN_ID=137 (mainnet) or 80001 (Mumbai). Default 137.
# TYCOON_POLYGON_CONTRACT_ADDRESS=
# BACKEND_GAME_CONTROLLER_POLYGON_PRIVATE_KEY=

# Base (optional; for Base frontend)
# BASE_RPC_URL=
# BASE_CHAIN_ID=8453 (mainnet) or 84531 (goerli). Default 8453.
# TYCOON_BASE_CONTRACT_ADDRESS=
# BACKEND_GAME_CONTROLLER_BASE_PRIVATE_KEY=

# Default chain when requests omit chain (User.normalizeChain / getChainConfig empty arg).
# Use CELO for Celo-only prod; use BASE for Base-only Railway deploys. Wrong value + wrong RPC_*_URL = silent mismatches.
# GUEST_CHAIN=CELO
# DEFAULT_APP_CHAIN=CELO

# --- TycoonTournamentEscrow (on-chain tournaments + staked Arena challenges) ---
# Required for staked agent-vs-agent / human-vs-agent arena: both escrow contract AND USDC token address for that chain.
# Escrow address per chain (must match deployed TycoonTournamentEscrow). Single-chain hack: set TOURNAMENT_ESCROW_ADDRESS only.
# TOURNAMENT_ESCROW_ADDRESS_CELO=0x...
# TOURNAMENT_ESCROW_ADDRESS_POLYGON=0x...
# TOURNAMENT_ESCROW_ADDRESS_BASE=0x...
# TOURNAMENT_ESCROW_ADDRESS=0x...   # optional fallback if you only run one chain
# USDC (6 decimals) token used for pulls from smart wallets → escrow:
# CELO_USDC_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C   # Celo mainnet native USDC; or set USDC_ADDRESS for all chains
# TYC ERC20 on Celo (optional; any one of):
# CELO_TYC_TOKEN_ADDRESS=0x...  # or TYCOON_CELO_TYC / TYCOON_CELO_TOKEN (same as frontend NEXT_PUBLIC_CELO_TYC)
# DashRunner (Celo) ERC1967 proxy (optional):
# CELO_DASHRUNNER_CONTRACT_ADDRESS=0x...   # or DASHRUNNER_CELO_CONTRACT_ADDRESS
# POLYGON_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Draw / tie refunds (entry-fee pool): house takes this % of the pool; the rest is split equally (e.g. 10 → 45%/45%/10% for two players). Default 5.
# TOURNAMENT_DRAW_HOUSE_CUT_PERCENT=10

# Autonomous agent-vs-agent tournament tables: match time limit in minutes (stored on the game; server runner uses it). Default 5. Set e.g. 30 for longer prod matches (allowed range 1–240).
# AGENT_TOURNAMENT_MATCH_DURATION_MIN=30

# After deploy, contract owner MUST call setBackend(gameControllerAddress) on the escrow.
# gameControllerAddress = the address derived from BACKEND_GAME_CONTROLLER_PRIVATE_KEY (same as Tycoon setBackendGameController).
# If createTournament reverts "Not backend or owner", backend on-chain does not match your signer — fix setBackend or keys.
# Optional: override escrow signer only (defaults to same key as BACKEND_GAME_CONTROLLER_* for that chain).
# TOURNAMENT_ESCROW_SIGNER_PRIVATE_KEY=0x...
# TOURNAMENT_ESCROW_SIGNER_PRIVATE_KEY_CELO=0x...
# TOURNAMENT_ESCROW_SIGNER_PRIVATE_KEY_POLYGON=0x...
# TOURNAMENT_ESCROW_SIGNER_PRIVATE_KEY_BASE=0x...

# --- Starknet / Dojo (Cairo) — Tycoon on Starknet Sepolia ---
# Optional. When set, backend can call Dojo contracts (register_player, create_ai_game, get_game_by_code).
# Used by services/starknetContract.js. Test: GET /api/config/starknet?test_connection=1
# STARKNET_RPC_URL=https://starknet-sepolia-rpc.publicnode.com
# BACKEND_STARKNET_PRIVATE_KEY=0x...   # Backend wallet (hex). Must have STRK for gas.
# BACKEND_STARKNET_ACCOUNT_ADDRESS=0x... # Same wallet address (Starknet account contract).
# Optional: override Dojo contract addresses (defaults match frontend manifest_sepolia.json).
# STARKNET_DOJO_GAME_ADDRESS=0x...
# STARKNET_DOJO_PLAYER_ADDRESS=0x...

# --- Internal AI agent (human vs AI games) ---
# When a human starts an AI game, the backend uses this agent to decide moves (buy, trade, build)
# instead of rule-based logic. One logical agent per game; no separate process.
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: set to "false" to disable internal agent and use built-in rules only.
# USE_INTERNAL_AI_AGENT=true
# Optional: auto-register these slots to use backend's Claude (no separate tycoon-celo-agent process).
# Agent is always online when backend runs. Example: TYCOON_INTERNAL_AGENT_SLOTS=2,3,4,5,6,7,8
# TYCOON_INTERNAL_AGENT_SLOTS=2,3,4,5,6,7,8
# Optional: model and timeout (default: claude-sonnet-4-20250514, 15000 ms).
# INTERNAL_AGENT_MODEL=claude-sonnet-4-20250514
# INTERNAL_AGENT_TIMEOUT_MS=15000
# Per-user daily cap for Tycoon-hosted agents (free tier). Default 100. Set to 0 to disable.
# HOSTED_AGENT_DAILY_CAP=100

# Set to true so "my agent" runs without checking or deducting credits (good for testing). Leave unset to use credits.
# HOSTED_AGENT_CREDITS_PAUSED=true
#
# Hosted agent credits purchase (USDC) — $1 = 100 credits
# CELO_USDC_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C (or NEXT_PUBLIC_CELO_USDC)
# HOSTED_AGENT_CREDITS_USDC_RECIPIENT=0x... (address to receive USDC; user sends $1, we verify and credit)

# --- ERC-8004 Agent Identity & Reputation (Celo) ---
# One-time: run backend/scripts/register-erc8004-agent.js to register your AI and get an agentId.
# AGENT_URI=https://base-monopoly.vercel.app/tycoon-ai.json
# ERC8004_REGISTRANT_PRIVATE_KEY=0x...   # optional: script falls back to BACKEND_GAME_CONTROLLER_PRIVATE_KEY
# After registration, set ERC8004_AGENT_ID so the backend submits reputation feedback after each AI game (user signs only once for claim).
# ERC8004_AGENT_ID=12345
# Optional: use a different wallet for submitting feedback (contract disallows "self feedback" - agent owner cannot submit for their own agent).
# Set this to a wallet that is NOT the one that registered the agent; wallet needs a little CELO for gas.
# ERC8004_FEEDBACK_PRIVATE_KEY=0x...
# Optional: URL stored in on-chain giveFeedback `endpoint` (8004scan / EIP profile).
# Default in code matches production decision route (omit this var to use it):
#   https://base-monopoly-production.up.railway.app/api/agent-registry/decision
# If your API is elsewhere, set to your origin + /api/agent-registry/decision, e.g. same as BACKEND_PUBLIC_URL + that path.
# ERC8004_FEEDBACK_ENDPOINT=https://base-monopoly-production.up.railway.app/api/agent-registry/decision
# Optional: Celo Reputation Registry address (default: 0x8004BAa17C55a88189AE136b182e5fdA19dE9b63)
# ERC8004_REPUTATION_REGISTRY_ADDRESS=0x...
# Optional: make GET /api/agents/:id/erc8004-registration match agentscan shape (Decision API + x402 service + x402Support). Requires public API origin (no trailing slash).
# BACKEND_PUBLIC_URL=https://your-api.up.railway.app
# ERC8004_REGISTRATION_X402_SUPPORT=true

# --- x402 Pay-per-use agent decisions (Celo) ---
# Optional. When set, POST /api/agent-registry/decision-paid requires payment in cUSD/USDC.
# Get THIRDWEB_SECRET_KEY from https://thirdweb.com dashboard.
# X402_PAY_TO_ADDRESS should be your TycoonRewardSystem contract (same as REWARD_CONTRACT_ADDRESS / TYCOON_REWARD_SYSTEM).
# THIRDWEB_SECRET_KEY=...
# X402_PAY_TO_ADDRESS=0x...   # e.g. same address as REWARD_CONTRACT_ADDRESS
# X402_DECISION_PRICE='$0.01'   # quote so the shell does not expand $0 if you source .env

# --- NGN payments (Flutterwave) — for perk bundle purchases in Naira ---
# From Flutterwave Dashboard → Settings → API Keys. Use test keys for development.
# FLW_SECRET_KEY=FLWSECK_TEST-... or FLWSECK-... (live)
# Optional: customer email sent to Flutterwave for shop + buy-CELO (default realjaiboi70@gmail.com). Must be a valid inbox if Flutterwave emails receipts.
# FLW_CHECKOUT_EMAIL=you@yourdomain.com
# Optional: set in Dashboard → Settings → Webhooks and verify in webhook handler (recommended).
# FLW_SECRET_HASH=your_webhook_secret_hash
# Public https origin (no trailing slash). Shop Naira redirect matches buy-CELO logic: client callback_url, else this, else http://localhost:3000 — then /game-shop is appended if needed.
# FRONTEND_URL=https://tycoonworld.xyz
# (Production app URL; also used as ERC-8004 registration fallback when the agent has no callback URL.)
# Optional: full URL to logo shown on Flutterwave checkout (e.g. https://yoursite.com/logo.png). If unset, uses FRONTEND_URL + /game/rewardrealm.svg when FRONTEND_URL is set.
# FLW_LOGO_URL=https://yoursite.com/logo.png
# Optional: customer phone for Flutterwave checkout (digits only, e.g. 2348031234567). Improves validation if dashboard requires a real MSISDN.
# FLW_CUSTOMER_PHONE=2348031234567

# -----------------------------------------------------------------------------
# Agent games (server-autonomous agent battles)
# -----------------------------------------------------------------------------
# When enabled, the backend automatically advances turns for games with
# game_type=AGENT_VS_AGENT or game_type=AGENT_VS_AI. This allows Agent-vs-Agent
# matches to keep playing even if no browser tab is open.
#
# ENABLE_AGENT_GAME_RUNNER=true
# Optional: poll interval (ms) for scanning runnable games (default: 2000)
# AGENT_GAME_RUNNER_POLL_MS=2000
# Optional: safety caps ONLY when game.duration is 0 (untimed agent games). Timed arena (duration > 0) ignores these.
# Set to 0 to disable that cap. These do not run on browser refresh — they use server clock / turn_count from real turns.
# UNTIMED_AGENT_GAME_WALLCLOCK_CAP_MIN=30
# UNTIMED_AGENT_GAME_TURN_CAP=250
# Arena: if a bot is still tied to an active match row longer than this (minutes), the old game is cancelled so they can join a new one (default 30).
# ARENA_AGENT_LOCK_STALE_MINUTES=30

# Timed human / AI sessions (duration > 0): backend periodically ends games when time is up (same as POST /games/:id/finish-by-time).
# Default 20000 ms. Set to 0 to disable the poller (then something else must call finish-by-time or finishGameByNetWorthAndNotify).
# TIMED_GAME_FINISH_POLL_MS=20000
# Retries staked-arena settlement and COMPLETED tournaments missing payout rows (stuck USDC). Default 60000 ms; set 0 to disable.
# TOURNAMENT_PAYOUT_RETRY_POLL_MS=60000

# --- Cost Optimization ---
# Sentry error/performance tracing (optional). Set DSN to enable; trace sampling controls cost.
# SENTRY_DSN=
# Trace sample rate (0.0–1.0): fraction of events traced. Production: 0.01 (1%). Development: 1.0 (100%).
# Default: 0.1 (10%) in production, 1.0 in development. Lower = lower Sentry bill.
# SENTRY_TRACE_SAMPLE_RATE=0.01

# Backend polling optimization (higher = fewer DB queries, slightly delayed updates).
# Agent game runner poll interval (ms). Default 2000. Production recommendation: 10000 (10s) or higher.
# AGENT_GAME_RUNNER_POLL_MS=10000
# Timed game finish poll interval (ms). Default 20000. Production recommendation: 60000 (60s) or higher.
# TIMED_GAME_FINISH_POLL_MS=60000

