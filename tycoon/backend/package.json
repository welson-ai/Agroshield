{
    "name": "agroshield-backend",
    "version": "1.0.0",
    "type": "module",
    "description": "AgroShield Agricultural Insurance Backend",
    "main": "server.js",
    "scripts": {
        "dev": "nodemon server.js",
        "start": "node server.js",
        "load-test": "k6 run ../scripts/load/load-test.js",
        "migrate": "knex migrate:latest",
        "migrate:rollback": "knex migrate:rollback",
        "migrate:rollback:all": "knex migrate:rollback --all",
        "migrate:make": "knex migrate:make",
        "migrate:status": "knex migrate:status",
        "seed": "knex seed:run",
        "seed:make": "knex seed:make",
        "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run",
        "list:guest-users": "node -r dotenv/config scripts/list-guest-users.js",
        "register-erc8004-agent": "node -r dotenv/config scripts/register-erc8004-agent.js",
        "finalize-tournament": "node -r dotenv/config scripts/finalize-tournament-admin.js",
        "seed:board-themes": "node -r dotenv/config scripts/seed-regional-board-themes.mjs"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.78.0",
        "@privy-io/node": "^0.10.0",
        "@socket.io/redis-adapter": "^8.3.0",
        "bcrypt": "^5.1.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "ethers": "^6.16.0",
        "express": "^4.18.2",
        "express-rate-limit": "^6.8.1",
        "helmet": "^7.0.0",
        "http": "^0.0.1-security",
        "joi": "^17.9.2",
        "jsonwebtoken": "^9.0.1",
        "knex": "^2.5.1",
        "@sentry/node": "^8.0.0",
        "mysql2": "^3.6.0",
        "pino": "^10.3.1",
        "redis": "^5.8.3",
        "socket.io": "^4.8.1",
        "starknet": "^6.23.0",
        "thirdweb": "^5.119.0"
    },
    "devDependencies": {
        "nodemon": "^3.0.1"
    }
}
