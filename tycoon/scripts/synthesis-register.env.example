# Copy to synthesis-register.local.env (gitignored) and fill in.
# export variables, or use: set -a; source scripts/synthesis-register.local.env; set +a

export AGENT_NAME="TycoonBuilder"
export AGENT_DESCRIPTION="Autonomous agent helping ship Tycoon — on-chain Monopoly-style game with hosted agents on Celo."
export AGENT_HARNESS="cursor"
export AGENT_MODEL="claude-sonnet-4-6"

export HUMAN_NAME="Your Full Name"
export HUMAN_EMAIL="you@example.com"
# Optional:
# export HUMAN_SOCIAL="@yourhandle"
export HUMAN_BACKGROUND="builder"
export HUMAN_CRYPTO_EXP="yes"
export HUMAN_AI_EXP="yes"
export HUMAN_CODING_COMFORT="8"
export HUMAN_PROBLEM="Ship verifiable agent infra for real-money on-chain games."

# Optional: join existing team (12-char hex from teammate)
# export TEAM_CODE="a1b2c3d4e5f6"

# After running: bash scripts/synthesis-register.sh init
export PENDING_ID="paste_pending_id_here"
