# Redeploy reward system + point proxy/registry at it (loads .env automatically):
#   ./run-deploy-reward-system.sh
#   ./run-deploy-reward-system.sh --verify   # needs ETHERSCAN_API_KEY
# Requires: TYC_ADDRESS, USDC_ADDRESS, TYCOON_PROXY_ADDRESS, GAME_CONTROLLER (see script header).

# Deployer (broadcast key). Must be TYCOON_OWNER to call setUserRegistry on proxy.
TYCOON_OWNER=0x...
PRIVATE_KEY=0x...

# RPC
RPC_URL=https://rpc.ankr.com/celo

# Reward system deploy (run-deploy-reward-system.sh)
TYC_ADDRESS=0x...
USDC_ADDRESS=0x...
GAME_CONTROLLER=0x...
TYCOON_USER_REGISTRY_ADDRESS=0x...

# Read-only: compare proxy.rewardSystem() vs registry.rewardSystemAddress() (no tx)
#   ./run-check-reward-system-alignment.sh
# Optional: also assert both equal this address
# TYCOON_EXPECTED_REWARD_SYSTEM=0x...

# After redeploying reward: point registry at same contract as game (registry owner PRIVATE_KEY)
#   ./run-set-user-registry-reward-system.sh
# Uses TYCOON_REWARD_SYSTEM if set; else copies TYCOON_PROXY_ADDRESS.rewardSystem()

# Required for DeployAndConfigureUserRegistry
TYCOON_PROXY_ADDRESS=0x...
TYCOON_REWARDS_FAUCET_ADDRESS=0x...
# Backend operator (can use same as GAME_CONTROLLER if one key runs backend)
OPERATOR_ADDRESS=0x...
# Signs withdrawals after user PIN (can use same as GAME_CONTROLLER)
WITHDRAWAL_AUTHORITY_ADDRESS=0x...

# Optional for DeployAndConfigureUserRegistry
TYCOON_NAIRA_VAULT_ADDRESS=0x...
TYCOON_REWARD_SYSTEM=0x...
DEFAULT_DAILY_CAP_USD6=100000000
DEFAULT_PRICE_CELO_USD6=2500000

# Optional: verification
ETHERSCAN_API_KEY=...

# --- Celo tournament escrow (after deploy) ---
# Deploy + verify + append to this file:
#   ./run-deploy-tournament-escrow.sh
#   ./run-deploy-tournament-escrow.sh --verify          # needs ETHERSCAN_API_KEY
#   ./run-deploy-tournament-escrow.sh --verify --write-env   # appends TYCOON_TOURNAMENT_ESCROW_ADDRESS + TOURNAMENT_ESCROW_ADDRESS_CELO
# Then set backend on escrow:
#   ./run-set-tournament-escrow-backend.sh
# Escrow address vars: TYCOON_TOURNAMENT_ESCROW_ADDRESS (verify script), TOURNAMENT_ESCROW_ADDRESS_CELO, TOURNAMENT_ESCROW_CELO,
# or frontend NEXT_PUBLIC_CELO_TOURNAMENT_ESCROW.
# BACKEND_GAME_CONTROLLER_PRIVATE_KEY — derive setBackend target; tx signed with PRIVATE_KEY (escrow owner) above.
